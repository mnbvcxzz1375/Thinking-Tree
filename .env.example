# ==============================================
# AI API Configuration - TEMPLATE
# Copy this file to .env and fill in your keys
# ==============================================

# Qwen DashScope API (Alibaba Cloud Bailian)
# Get your key: https://bailian.console.aliyun.com/?tab=model#/api
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
# Model: qwen3.5-omni-plus-realtime (recommended) or qwen3.5-omni-flash-realtime (cheaper)
QWEN_MODEL=qwen3.5-omni-flash-realtime
# Region: cn (Beijing) or intl (Singapore)
QWEN_REGION=cn
# WebSocket endpoint (auto-derived from region)
QWEN_WS_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# MiMo API (Xiaomi)
# Get your key: https://platform.xiaomimimo.com/console/plan-manage
MIMO_API_KEY=tp-your-mimo-api-key-here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=MiMo-V2.5

# Server Configuration
HOST=127.0.0.1
PORT=8765

# Audio Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_BIT_DEPTH=16
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=3200
