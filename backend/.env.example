# ==============================================
# Backend Configuration - TEMPLATE
# Copy this file to .env and fill in your values
# ==============================================

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/thinking_tree
DATABASE_ECHO=false

# Server Configuration
HOST=127.0.0.1
PORT=8765
DEBUG=true

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:5173"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AI API Configuration - Qwen DashScope
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen3.5-omni-plus-realtime
QWEN_REGION=cn
QWEN_WS_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# AI API Configuration - MiMo
MIMO_API_KEY=tp-your-mimo-api-key-here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=MiMo-V2.5

# AI Provider Selection (qwen or mimo)
AI_PROVIDER=qwen
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=3

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Audio Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_BIT_DEPTH=16
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=3200
